<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register | Krishi Sarthi</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/footer.css" />
    <link rel="stylesheet" href="/css/register.css" />
  </head>
  <body>
    <%- include("../partials/navbar") %> <%- include("../partials/flash") %>
    <!-- Register Section -->

    <section class="register-section">
      <div class="register-box">
        <h1>Create Account 🌱</h1>

        <p>Join Krishi Sarthi and start smart farming.</p>

        <form action="/user/signup" method="POST">
          <div class="input-box">
            <i class="fas fa-user"></i>
            <input type="text" name="name" placeholder="Full Name" required />
          </div>

          <div class="input-box">
            <i class="fas fa-envelope"></i>
            <input
              type="email"
              name="email"
              placeholder="Email Address"
              required
            />
          </div>
          <div class="input-box">
            <i class="fa-solid fa-mountain-city"></i>
            <input type="text" name="village" placeholder="Village" required />
          </div>
          <div class="input-box">
            <i class="fa-solid fa-city"></i>
            <input type="text" name="city" placeholder="City" required />
          </div>

          <div class="input-box">
            <i class="fa-solid fa-earth-europe"></i>
            <input type="text" name="country" placeholder="Country" required />
          </div>

          <div class="input-box">
            <i class="fa-solid fa-seedling"></i>

            <input
              type="number"
              name="area"
              placeholder="Enter land area (select unit below first)"
              min="0"
              step="0.01"
              required
            />

            <select name="areaUnit" required>
              <option value="acre">Acre</option>
              <option value="hectare">Hectare</option>
              <option value="bigha">Bigha</option>
              <option value="guntha">Guntha</option>
              <option value="kanal">Kanal</option>
              <option value="cent">Cent</option>
            </select>
          </div>

          <div class="input-box">
            <i class="fas fa-phone"></i>
            <input
              type="tel"
              name="phone"
              placeholder="Phone Number"
              required
            />
          </div>

          <div class="input-box">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              name="password"
              placeholder="Create Password"
              required
            />
          </div>

          <div class="input-box">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              name="confirmPassword"
              placeholder="Confirm Password"
              required
            />
          </div>

          <button type="submit" class="btn">Register</button>
        </form>

        <p class="register-link">
          Already have an account?
          <a href="/user/login">Login Here</a>
        </p>
      </div>
    </section>

    <%- include("../partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/register.js"></script>
  </body>
</html>
