<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estimated Cost | Krishi Sarthi</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/cost.css">
</head>
<body>
 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 

<!-- Banner -->

<section class="page-banner">

    <h1>🧮 Estimated Cost Calculator</h1>

    <p>
        Calculate the total cultivation cost before starting farming.
    </p>

</section>

<!-- Cost Form -->

<section class="form-section">

<div class="form-card">

<h2>Enter Farming Expenses</h2>

<form action="/cost" method="POST">

<div class="form-group">
<label>Crop Name</label>
<input type="text" name="crop" required>
</div>

<div class="form-group">
<label>Land Area (Acres)</label>
<input type="number" step="0.1" name="land" required>
</div>

<div class="form-group">
<label>Seed Cost (₹)</label>
<input type="number" name="seed" required>
</div>

<div class="form-group">
<label>Fertilizer Cost (₹)</label>
<input type="number" name="fertilizer" required>
</div>

<div class="form-group">
<label>Labour Cost (₹)</label>
<input type="number" name="labour" required>
</div>

<div class="form-group">
<label>Irrigation Cost (₹)</label>
<input type="number" name="irrigation" required>
</div>

<div class="form-group">
<label>Other Expenses (₹)</label>
<input type="number" name="others" required>
</div>

<button class="btn" type="submit">
Calculate Cost
</button>

</form>

</div>

</section>

<!-- Result -->

<section class="form-section">

<div class="result-card">

<h3>Estimated Total Cost</h3>

<p><strong>Total Estimated Cost:</strong> ₹0</p>

<p>
The total cultivation cost will be displayed here after calculation.
</p>

</div>

</section>

<!-- Cost Categories -->

<section class="features">

<h2>Cost Breakdown</h2>

<div class="feature-grid">

<div class="feature-card">
<i class="fas fa-seedling"></i>
<h3>Seeds</h3>
<p>High-quality seeds improve productivity.</p>
</div>

<div class="feature-card">
<i class="fas fa-flask"></i>
<h3>Fertilizers</h3>
<p>Essential nutrients for healthy crop growth.</p>
</div>

<div class="feature-card">
<i class="fas fa-users"></i>
<h3>Labour</h3>
<p>Estimate manpower expenses accurately.</p>
</div>

<div class="feature-card">
<i class="fas fa-tint"></i>
<h3>Irrigation</h3>
<p>Include water and irrigation system costs.</p>
</div>

</div>

</section>

<!-- Tips -->

<section class="features">

<h2>Cost Saving Tips</h2>

<div class="feature-grid">

<div class="feature-card">
<h3>💧 Save Water</h3>
<p>Use drip irrigation to reduce water expenses.</p>
</div>

<div class="feature-card">
<h3>🌱 Buy Quality Seeds</h3>
<p>Good seeds increase yield and reduce losses.</p>
</div>

<div class="feature-card">
<h3>📦 Plan Purchases</h3>
<p>Purchase fertilizers and equipment in advance.</p>
</div>

</div>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script src="/js/cost.js"></script>

</body>
</html>