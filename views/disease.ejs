<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disease Prediction | Krishi Sarthi</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<   <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/disease.css">
</head>
<body>
 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 
<!-- Banner -->

<section class="page-banner">

    <h1>🍃 AI Disease Prediction</h1>

    <p>
        Upload a crop leaf image and detect diseases
        using Artificial Intelligence.
    </p>

</section>

<!-- Upload Form -->

<section class="form-section">

<div class="form-card">

<h2>Upload Leaf Image</h2>

<form action="/disease"
      method="POST"
      enctype="multipart/form-data">

<div class="form-group">

<label>Select Crop</label>

<select name="crop">

<option>Rice</option>
<option>Wheat</option>
<option>Tomato</option>
<option>Potato</option>
<option>Cotton</option>
<option>Maize</option>

</select>

</div>

<div class="form-group">

<label>Upload Leaf Image</label>

<input type="file"
name="leafImage"
accept="image/*"
required>

</div>

<button class="btn">

Predict Disease

</button>

</form>

</div>

</section>

<!-- Prediction Result -->

<section class="form-section">

<div class="result-card">

<h3>Prediction Result</h3>

<p><strong>Disease:</strong> Waiting for Prediction</p>

<p><strong>Confidence:</strong> --%</p>

<p><strong>Treatment:</strong>
Recommended solution will appear here.
</p>

</div>

</section>

<!-- Features -->

<section class="features">

<h2>Why Choose AI Disease Detection?</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-camera"></i>

<h3>Image Analysis</h3>

<p>
Detect diseases using uploaded leaf images.
</p>

</div>

<div class="feature-card">

<i class="fas fa-microscope"></i>

<h3>Accurate Prediction</h3>

<p>
AI model trained on thousands of crop images.
</p>

</div>

<div class="feature-card">

<i class="fas fa-kit-medical"></i>

<h3>Treatment Advice</h3>

<p>
Receive prevention and treatment suggestions.
</p>

</div>

</div>

</section>

<!-- Steps -->

<section class="features">

<h2>How It Works</h2>

<div class="feature-grid">

<div class="feature-card">

<h3>1️⃣ Upload</h3>

<p>Select a healthy image of the crop leaf.</p>

</div>

<div class="feature-card">

<h3>2️⃣ AI Analysis</h3>

<p>The model analyzes the uploaded image.</p>

</div>

<div class="feature-card">

<h3>3️⃣ Result</h3>

<p>View disease name and suggested treatment.</p>

</div>

</div>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script src="/js/disease.js"></script>

</body>
</html>