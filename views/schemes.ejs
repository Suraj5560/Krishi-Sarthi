<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Government Schemes | Krishi Sarthi</title>

    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/schemes.css">


</head>
<body>

 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 

<!-- Banner -->

<section class="page-banner">

    <h1>🏛 Government Schemes</h1>

    <p>
        Explore government schemes and subsidies available for farmers.
    </p>

</section>

<!-- Search -->

<section class="form-section">

<div class="form-card">

<h2>Find a Scheme</h2>

<form action="/schemes" method="POST">

<div class="form-group">

<label>Select State</label>

<select name="state">

<option>Delhi</option>
<option>Punjab</option>
<option>Haryana</option>
<option>Uttar Pradesh</option>
<option>Maharashtra</option>
<option>Rajasthan</option>
<option>Bihar</option>
<option>Gujarat</option>

</select>

</div>

<div class="form-group">

<label>Farmer Category</label>

<select name="category">

<option>Small Farmer</option>
<option>Marginal Farmer</option>
<option>Medium Farmer</option>
<option>Large Farmer</option>

</select>

</div>

<button class="btn" type="submit">

Search Schemes

</button>

</form>

</div>

</section>

<!-- Scheme Cards -->

<section class="features">

<h2>Popular Government Schemes</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-hand-holding-dollar"></i>

<h3>PM-KISAN</h3>

<p>

Income support of ₹6,000 per year for eligible farmers.

</p>

</div>

<div class="feature-card">

<i class="fas fa-seedling"></i>

<h3>Soil Health Card</h3>

<p>

Get soil testing reports and fertilizer recommendations.

</p>

</div>

<div class="feature-card">

<i class="fas fa-tractor"></i>

<h3>SMAM</h3>

<p>

Subsidy on modern agricultural machinery and equipment.

</p>

</div>

<div class="feature-card">

<i class="fas fa-shield-halved"></i>

<h3>PM Fasal Bima Yojana</h3>

<p>

Crop insurance to protect farmers from crop losses.

</p>

</div>

</div>

</section>

<!-- Eligibility -->

<section class="features">

<h2>Eligibility Benefits</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-money-bill-wave"></i>

<h3>Financial Support</h3>

<p>

Receive direct financial assistance from eligible schemes.

</p>

</div>

<div class="feature-card">

<i class="fas fa-flask"></i>

<h3>Agriculture Services</h3>

<p>

Access soil testing and agricultural advisory services.

</p>

</div>

<div class="feature-card">

<i class="fas fa-leaf"></i>

<h3>Crop Protection</h3>

<p>

Insurance and disaster protection for your crops.

</p>

</div>

</div>

</section>

<!-- CTA -->

<section class="form-section">

<div class="result-card">

<h3>Need Help?</h3>

<p>

Our AI Assistant can help you find the most suitable
government scheme based on your profile.

</p>

<a href="/chatbot" class="btn">

Ask AI Assistant

</a>

</div>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script src="/js/schemes.js"></script>

</body>
</html>