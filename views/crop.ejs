<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crop Recommendation | Krishi Sarthi</title>


<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/crop.css">
</head>
<body>

 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 

<!-- Banner -->

<section class="page-banner">

    <h1>🌾 AI Crop Recommendation</h1>

    <p>
        Get the most suitable crop based on your soil
        and environmental conditions.
    </p>

</section>

<!-- Form -->

<section class="form-section">

<div class="form-card">

<h2>Enter Crop Details</h2>

<form action="/crop" method="POST">

<div class="form-group">
<label>Nitrogen (N)</label>
<input type="number" name="nitrogen" required>
</div>

<div class="form-group">
<label>Phosphorus (P)</label>
<input type="number" name="phosphorus" required>
</div>

<div class="form-group">
<label>Potassium (K)</label>
<input type="number" name="potassium" required>
</div>

<div class="form-group">
<label>Temperature (°C)</label>
<input type="number" step="0.1" name="temperature" required>
</div>

<div class="form-group">
<label>Humidity (%)</label>
<input type="number" step="0.1" name="humidity" required>
</div>

<div class="form-group">
<label>Soil pH</label>
<input type="number" step="0.1" name="ph" required>
</div>

<div class="form-group">
<label>Rainfall (mm)</label>
<input type="number" step="0.1" name="rainfall" required>
</div>

<button class="btn" type="submit">
Analyze Crop
</button>

</form>

</div>

</section>

<!-- Result -->

<section class="form-section">

<div class="result-card">

<h3>Recommended Crop</h3>

<p>

Your AI prediction result will appear here after
submitting the form.

</p>

</div>

</section>

<!-- Benefits -->

<section class="features">

<h2>Why Use AI Crop Recommendation?</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-seedling"></i>

<h3>Better Yield</h3>

<p>Select crops suitable for your soil.</p>

</div>

<div class="feature-card">

<i class="fas fa-leaf"></i>

<h3>Healthy Farming</h3>

<p>Reduce crop failures using AI insights.</p>

</div>

<div class="feature-card">

<i class="fas fa-chart-line"></i>

<h3>Higher Profit</h3>

<p>Choose crops with better profitability.</p>

</div>

</div>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script src="/js/crop.js"></script>

</body>
</html>