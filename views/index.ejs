<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Krishi Sarthi | Smart Farming</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="stylesheet" href="/css/footer.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
  </head>

  <body>
 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 

    <!-- ================= HERO ================= -->

    <section class="hero">
      <div class="hero-content">
        <div class="hero-left">
          <span class="hero-badge">
            This is an AI Powered Agriculture Platform
          </span>

          <h1>Smart Farming Begins With Krishi Sarthi</h1>

          <p>
            Empowering farmers with Artificial Intelligence to recommend crops,
            detect diseases, predict profits and provide weather updates.
          </p>

          <div class="hero-buttons">
            <a href="/user/signup" class="btn"> Get Started </a>

            <a href="/about" class="btn btn-outline"> Learn More </a>
          </div>
        </div>

        <div class="hero-right">
          <img src="/images/plant.jpg" alt="plant" />
        </div>
      </div>
    </section>

    <!-- ================= SEARCH ================= -->

    <section class="search-section">
      <h2>Search Agricultural Information Here</h2>

      <p>
        Search for crops ,plant disease, weather updates, government scheme,
        fertilizers, and farming guidance.
      </p>

      <div class="search-box">
        <input type="text" placeholder="Search here..." />

        <button class="btn">Search</button>
      </div>
    </section>

    <!-- ================= STATS ================= -->

    <section class="stats">
      <div class="stat-card">
        <i class="fas fa-users"></i>

        <h2 class="counter" data-target="10000">0</h2>

        <p>Farmers Benefited</p>
      </div>

      <div class="stat-card">
        <i class="fas fa-seedling"></i>

        <h2 class="counter" data-target="50">0</h2>

        <p>Supported Crops</p>
      </div>

      <div class="stat-card">
        <i class="fas fa-chart-line"></i>

        <h2 class="counter" data-target="96">0</h2>

        <p>Prediction Accuracy</p>
      </div>

      <div class="stat-card">
        <i class="fas fa-cloud-sun"></i>

        <h2>24×7</h2>

        <p>Weather Monitoring</p>
      </div>
    </section>

    <!-- ================= DASHBOARD PREVIEW ================= -->

    <section class="dashboard-preview">
      <h2>Farmer Dashboard Preview</h2>

      <div class="dashboard-grid">
        <div class="dashboard-card">
          <i class="fas fa-cloud-sun"></i>

          <h3>Today's Weather</h3>

          <p>31°C</p>

          <span> Sunny </span>
        </div>

        <div class="dashboard-card">
          <i class="fas fa-leaf"></i>

          <h3>Recommended Crop</h3>

          <p>Rice</p>

          <span> Best for Current Soil </span>
        </div>

        <div class="dashboard-card">
          <i class="fas fa-bug"></i>

          <h3>Disease Status</h3>

          <p>Healthy</p>

          <span> No Infection Found </span>
        </div>

        <div class="dashboard-card">
          <i class="fas fa-wallet"></i>

          <h3>Estimated Profit</h3>

          <p>₹75,000</p>

          <span> Expected This Season </span>
        </div>
      </div>
    </section>

    <!-- ================= OUR SERVICES ================= -->

    <section class="services">
      <h2>Our Smart Farming Services</h2>

      <p class="section-subtitle">
        AI-powered solutions designed to help farmers make better decisions.
      </p>

      <div class="service-grid">
        <div class="service-card">
          <i class="fas fa-seedling"></i>
          <h3>Crop Recommendation</h3>
          <p>Get the most suitable crop based on soil nutrients and climate.</p>
          <a href="/crop" class="service-btn">Explore</a>
        </div>

        <div class="service-card">
          <i class="fas fa-leaf"></i>
          <h3>Disease Prediction</h3>
          <p>
            Upload crop images and detect diseases using Artificial
            Intelligence.
          </p>
          <a href="/disease" class="service-btn">Explore</a>
        </div>

        <div class="service-card">
          <i class="fas fa-chart-line"></i>
          <h3>Profit Prediction</h3>
          <p>Estimate your expected farming profit before cultivation.</p>
          <a href="/profit" class="service-btn">Explore</a>
        </div>

        <div class="service-card">
          <i class="fas fa-calculator"></i>
          <h3>Cost Estimation</h3>
          <p>
            Calculate fertilizer, labour, irrigation and transportation cost.
          </p>
          <a href="/cost" class="service-btn">Explore</a>
        </div>

        <div class="service-card">
          <i class="fas fa-cloud-sun-rain"></i>
          <h3>Weather Forecast</h3>
          <p>Receive live weather updates and rainfall predictions.</p>
          <a href="/weather" class="service-btn">Explore</a>
        </div>

        <div class="service-card">
          <i class="fas fa-robot"></i>
          <h3>AI Chatbot</h3>
          <p>Ask farming questions and get instant AI-powered assistance.</p>
          <a href="/chatbot" class="service-btn">Explore</a>
        </div>
      </div>
    </section>

    <!-- ================= AI WORKFLOW ================= -->

    <section class="workflow">
      <h2>How Krishi Sarthi Works</h2>

      <div class="workflow-container">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Enter Farm Details</h3>
          <p>Provide soil nutrients, weather and crop information.</p>
        </div>

        <div class="arrow">
          <i class="fas fa-arrow-right"></i>
        </div>

        <div class="step">
          <div class="step-number">2</div>
          <h3>AI Analysis</h3>
          <p>Machine learning models analyze your farming data.</p>
        </div>

        <div class="arrow">
          <i class="fas fa-arrow-right"></i>
        </div>

        <div class="step">
          <div class="step-number">3</div>
          <h3>Smart Recommendation</h3>
          <p>Receive crop suggestions, disease reports and profit analysis.</p>
        </div>
      </div>
    </section>

    <!-- ================= CROP SECTION ================= -->

    <section class="feature-section">
      <div class="feature-image">
        <img src="/images/crop.jpeg" alt="Crop Recommendation" />
      </div>

      <div class="feature-content">
        <span>🌾 AI Crop Recommendation</span>

        <h2>Choose The Right Crop Every Season</h2>

        <p>
          Our AI model analyzes soil nutrients, rainfall, temperature and
          humidity to recommend the most profitable crop.
        </p>

        <ul>
          <li>✔ Soil Analysis</li>
          <li>✔ Climate Prediction</li>
          <li>✔ High Accuracy</li>
          <li>✔ Instant Results</li>
        </ul>

        <a href="/crop" class="btn"> Analyze Crop </a>
      </div>
    </section>

    <!-- ================= DISEASE SECTION ================= -->

    <section class="feature-section reverse">
      <div class="feature-content">
        <span>🍃 Disease Detection</span>

        <h2>Detect Diseases Before They Spread</h2>

        <p>
          Upload an image of your crop leaf and let Artificial Intelligence
          identify diseases within seconds.
        </p>

        <ul>
          <li>✔ Upload Image</li>

          <li>✔ AI Detection</li>

          <li>✔ Confidence Score</li>

          <li>✔ Treatment Suggestions</li>
        </ul>

        <a href="/disease" class="btn"> Predict Disease </a>
      </div>

      <div class="feature-image">
        <img src="/images/disease.jpeg" alt="Disease" />
      </div>
    </section>

    <!-- ================= PROFIT PREVIEW ================= -->

    <section class="profit-preview">
      <h2>Estimate Your Farming Profit</h2>

      <div class="profit-grid">
        <div class="profit-box">
          <i class="fas fa-coins"></i>

          <h3>Revenue</h3>

          <p>Estimate total revenue using production and market prices.</p>
        </div>

        <div class="profit-box">
          <i class="fas fa-wallet"></i>

          <h3>Expenses</h3>

          <p>Calculate fertilizer, labour, irrigation and transport costs.</p>
        </div>

        <div class="profit-box">
          <i class="fas fa-chart-line"></i>

          <h3>Net Profit</h3>

          <p>Understand your expected profit before cultivation.</p>
        </div>
      </div>

      <div class="center">
        <a href="/profit" class="btn"> Calculate Profit </a>
      </div>
    </section>

    <!-- ================= WEATHER ================= -->

    <section class="weather-section">
      <h2>Live Weather Forecast</h2>

      <p class="section-subtitle">
        Stay prepared with real-time weather information.
      </p>

      <div class="weather-grid">
        <div class="weather-card">
          <i class="fas fa-temperature-high"></i>
          <h3>Temperature</h3>
          <h2>31°C</h2>
          <span>Sunny</span>
        </div>

        <div class="weather-card">
          <i class="fas fa-cloud-rain"></i>
          <h3>Humidity</h3>
          <h2>68%</h2>
          <span>Good</span>
        </div>

        <div class="weather-card">
          <i class="fas fa-wind"></i>
          <h3>Wind Speed</h3>
          <h2>12 km/h</h2>
          <span>Moderate</span>
        </div>

        <div class="weather-card">
          <i class="fas fa-cloud-showers-heavy"></i>
          <h3>Rainfall</h3>
          <h2>85 mm</h2>
          <span>Expected</span>
        </div>
      </div>

      <div class="center">
        <a href="/weather" class="btn"> Check Detailed Forecast </a>
      </div>
    </section>

    <!-- ================= GOVERNMENT SCHEMES ================= -->

    <section class="schemes">
      <h2>Government Schemes</h2>

      <p class="section-subtitle">
        Explore schemes and subsidies available for farmers.
      </p>

      <div class="scheme-grid">
        <div class="scheme-card">
          <i class="fas fa-hand-holding-dollar"></i>

          <h3>PM-KISAN</h3>

          <p>Financial assistance for eligible farmers.</p>

          <a href="/schemes">Know More</a>
        </div>

        <div class="scheme-card">
          <i class="fas fa-tractor"></i>

          <h3>Farm Machinery</h3>

          <p>Subsidies on modern agricultural equipment.</p>

          <a href="/schemes">Know More</a>
        </div>

        <div class="scheme-card">
          <i class="fas fa-shield-alt"></i>

          <h3>Crop Insurance</h3>

          <p>Protect crops against natural disasters.</p>

          <a href="/schemes">Know More</a>
        </div>

        <div class="scheme-card">
          <i class="fas fa-seedling"></i>

          <h3>Soil Health Card</h3>

          <p>Improve soil quality using scientific reports.</p>

          <a href="/schemes">Know More</a>
        </div>
      </div>
    </section>

    <!-- ================= AGRICULTURE NEWS ================= -->

    <section class="news-section">
      <h2>Latest Agriculture News</h2>

      <div class="news-grid">
        <div class="news-card">
          <img src="/images/news1.jpeg" alt="News" />

          <h3>New Government Subsidy Announced</h3>

          <p>
            Farmers can now receive additional benefits under the latest scheme.
          </p>
        </div>

        <div class="news-card">
          <img src="/images/news2.jpeg" alt="News" />

          <h3>Rainfall Expected Next Week</h3>

          <p>
            Weather department predicts moderate rainfall across many regions.
          </p>
        </div>

        <div class="news-card">
          <img src="/images/news3.jpeg" alt="News" />

          <h3>Smart Farming Technologies</h3>

          <p>AI and IoT continue transforming modern agriculture.</p>
        </div>
      </div>
    </section>

    <!-- ================= FARMER SUCCESS ================= -->

    <section class="success">
      <h2>Our Impact</h2>

      <div class="success-grid">
        <div class="success-card">
          <i class="fas fa-users"></i>

          <h2>10,000+</h2>

          <p>Registered Farmers</p>
        </div>

        <div class="success-card">
          <i class="fas fa-map-marker-alt"></i>

          <h2>250+</h2>

          <p>Villages Connected</p>
        </div>

        <div class="success-card">
          <i class="fas fa-award"></i>

          <h2>96%</h2>

          <p>Prediction Accuracy</p>
        </div>

        <div class="success-card">
          <i class="fas fa-seedling"></i>

          <h2>50+</h2>

          <p>Supported Crops</p>
        </div>
      </div>
    </section>

    <!-- ================= WHY KRISHI SARTHI ================= -->

    <section class="benefits">
      <h2>Why Farmers Trust Krishi Sarthi</h2>

      <div class="benefit-grid">
        <div class="benefit-card">
          <i class="fas fa-brain"></i>

          <h3>AI Powered</h3>

          <p>
            Advanced machine learning models provide accurate farming
            recommendations.
          </p>
        </div>

        <div class="benefit-card">
          <i class="fas fa-mobile-alt"></i>

          <h3>Easy To Use</h3>

          <p>Simple interface designed for farmers and agriculture students.</p>
        </div>

        <div class="benefit-card">
          <i class="fas fa-clock"></i>

          <h3>24×7 Available</h3>

          <p>Access farming services anytime from anywhere.</p>
        </div>

        <div class="benefit-card">
          <i class="fas fa-lock"></i>

          <h3>Secure Platform</h3>

          <p>Your farming information remains safe and protected.</p>
        </div>
      </div>
    </section>

    <!-- ================= TESTIMONIALS ================= -->

    <section class="testimonials">
      <h2>What Farmers Say</h2>

      <p class="section-subtitle">
        Trusted by thousands of farmers across India.
      </p>

      <div class="testimonial-grid">
        <div class="testimonial-card">
          <img src="/images/user.jpeg" alt="Farmer" />

          <h3>Ramesh Kumar</h3>

          <p>
            "Krishi Sarthi recommended the perfect crop for my farm. My yield
            increased significantly."
          </p>

          <div class="stars">⭐⭐⭐⭐⭐</div>
        </div>

        <div class="testimonial-card">
          <img src="/images/user1.jpeg" alt="Farmer" />

          <h3>Suresh Patel</h3>

          <p>
            "Disease prediction helped me detect infection before it spread
            across my field."
          </p>

          <div class="stars">⭐⭐⭐⭐⭐</div>
        </div>

        <div class="testimonial-card">
          <img src="/images/user2.jpeg" alt="Farmer" />

          <h3>Priya Sharma</h3>

          <p>
            "Profit estimation helped me plan cultivation and reduce unnecessary
            expenses."
          </p>

          <div class="stars">⭐⭐⭐⭐⭐</div>
        </div>
      </div>
    </section>

    <!-- ================= FAQ ================= -->

    <section class="faq">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-container">
        <div class="faq-item">
          <h3>How does Crop Recommendation work?</h3>

          <p>
            It analyzes soil nutrients, temperature, humidity and rainfall to
            suggest the best crop.
          </p>
        </div>

        <div class="faq-item">
          <h3>Is Disease Prediction AI based?</h3>

          <p>
            Yes. Upload a crop image and Artificial Intelligence predicts
            possible diseases.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can I check weather updates?</h3>

          <p>
            Yes, weather forecasting is available to help farmers plan their
            activities.
          </p>
        </div>

        <div class="faq-item">
          <h3>Is Krishi Sarthi free?</h3>

          <p>
            Yes. This project is developed for educational and farming support.
          </p>
        </div>
      </div>
    </section>

    <!-- ================= NEWSLETTER ================= -->

    <section class="newsletter">
      <h2>Subscribe for Agriculture Updates</h2>

      <p>Receive weather alerts, government schemes, and farming tips.</p>

      <form class="newsletter-form">
        <input type="email" placeholder="Enter Email" required />

        <button type="submit">Subscribe</button>
      </form>
    </section>

    <!-- ================= CALL TO ACTION ================= -->

    <section class="cta">
      <h2>Ready to Transform Farming?</h2>

      <p>
        Join thousands of farmers using Artificial Intelligence for smarter
        agriculture.
      </p>

      <a href="/register" class="btn"> Create Account </a>
    </section>

    <!-- ================= FLOATING CHAT ================= -->

    <a href="/chatbot" class="floating-chat">
      <i class="fas fa-comments"></i>
    </a>

    <!-- ================= SCROLL TOP ================= -->

    <button id="scrollTop">
      <i class="fas fa-arrow-up"></i>
    </button>

    <!-- ================= FOOTER ================= -->

    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>

    <script src="/js/home.js"></script>
  </body>
</html>
