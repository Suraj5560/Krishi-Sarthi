<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Krishi Sarthi</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 
<!-- Dashboard Banner -->

<section class="dashboard-banner">

    <h1>👨‍🌾 Farmer Dashboard</h1>

    <p>Welcome to your Smart Farming Dashboard</p>

</section>

<!-- Statistics -->

<section class="dashboard-stats">

    <div class="dash-card">
        <i class="fas fa-seedling"></i>
        <h2 class="counter" data-target="8">0</h2>
        <p>Crop Prediction</p>
    </div>

    <div class="dash-card">
        <i class="fas fa-leaf"></i>
        <h2 class="counter" data-target="8">0</h2>
        <p>Disease Reports</p>
    </div>

    <div class="dash-card">
        <i class="fas fa-chart-line"></i>
        <h2 class="counter" data-target="₹1.8L">0</h2>
        <p>Estimated Profit</p>
    </div>

    <div class="dash-card">
        <i class="fas fa-cloud-sun"></i>
        <h2 class="counter" data-target="31°C">0</h2>
        <p>Today's Weather</p>
    </div>

</section>

<!-- Quick Access -->

<section class="dashboard-features">

<h2>Quick Access</h2>

<div class="feature-grid">

<a href="/crop" class="feature-card">
<i class="fas fa-seedling"></i>
<h3>Crop Recommendation</h3>
</a>

<a href="/disease" class="feature-card">
<i class="fas fa-virus"></i>
<h3>Disease Prediction</h3>
</a>

<a href="/profit" class="feature-card">
<i class="fas fa-chart-line"></i>
<h3>Profit Prediction</h3>
</a>

<a href="/cost" class="feature-card">
<i class="fas fa-calculator"></i>
<h3>Estimated Cost</h3>
</a>

<a href="/weather" class="feature-card">
<i class="fas fa-cloud-rain"></i>
<h3>Weather</h3>
</a>

<a href="/chatbot" class="feature-card">
<i class="fas fa-robot"></i>
<h3>AI Chatbot</h3>
</a>

</div>

</section>

<!-- Recent Activity -->

<section class="activity">

<h2>Recent Activity</h2>

<ul>

<li>✅ Crop Recommendation completed successfully.</li>

<li>🌱 Disease prediction report generated.</li>

<li>💰 Profit estimation calculated.</li>

<li>🌦 Weather forecast updated.</li>

</ul>

</section>

<!-- Weather Card -->

<section class="weather-widget">

<h2>Today's Weather</h2>

<div class="weather-box">

<h3>🌤 Sunny</h3>

<p>Temperature : 31°C</p>

<p>Humidity : 65%</p>

<p>Wind Speed : 10 km/h</p>

</div>

</section>

<!-- CTA -->

<section class="cta">

<h2>Grow Smarter with AI</h2>

<p>
Use our intelligent farming tools to improve
productivity and maximize profits.
</p>

<a href="/crop" class="btn">
Start Analysis
</a>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script src="/js/dashboard.js"></script>

</body>
</html>