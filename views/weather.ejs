<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather Forecast | Krishi Sarthi</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/footer.css" />
    <link rel="stylesheet" href="/css/weather.css" />
  </head>
  <body>
    <%- include("partials/navbar") %> <%- include("partials/flash") %>

    <!-- Banner -->

    <section class="page-banner">
      <h1>🌦️ Weather Forecast</h1>

      <p>
        Check live weather conditions before planning your farming activities.
      </p>
    </section>

    <!-- Search -->

    <section class="form-section">
      <div class="form-card">
        <h2>Search Weather</h2>

        <form action="/weather" method="POST">
          <div class="form-group">
            <label>Enter City / Village</label>

            <input
              type="text"
              name="location"
              placeholder="e.g. Delhi"
              required
            />
          </div>

          <button class="btn" type="submit">Get Weather</button>
        </form>
      </div>
    </section>

    <!-- Current Weather -->

    <section class="weather-container">
      <div class="weather-card">
        <i class="fas fa-temperature-high"></i>

        <h3>Temperature</h3>

        <p>32°C</p>
      </div>

      <div class="weather-card">
        <i class="fas fa-cloud"></i>

        <h3>Condition</h3>

        <p>Partly Cloudy</p>
      </div>

      <div class="weather-card">
        <i class="fas fa-tint"></i>

        <h3>Humidity</h3>

        <p>68%</p>
      </div>

      <div class="weather-card">
        <i class="fas fa-wind"></i>

        <h3>Wind Speed</h3>

        <p>12 km/h</p>
      </div>
    </section>

    <!-- 5 Day Forecast -->

    <section class="features">
      <h2>5-Day Forecast</h2>

      <div class="feature-grid">
        <div class="feature-card">
          <h3>Monday</h3>
          <p>☀️ 33°C / 25°C</p>
        </div>

        <div class="feature-card">
          <h3>Tuesday</h3>
          <p>🌤️ 32°C / 24°C</p>
        </div>

        <div class="feature-card">
          <h3>Wednesday</h3>
          <p>🌧️ 29°C / 23°C</p>
        </div>

        <div class="feature-card">
          <h3>Thursday</h3>
          <p>⛅ 31°C / 24°C</p>
        </div>

        <div class="feature-card">
          <h3>Friday</h3>
          <p>☀️ 34°C / 25°C</p>
        </div>
      </div>
    </section>

    <!-- Farming Tips -->

    <section class="features">
      <h2>Weather Advisory</h2>

      <div class="feature-grid">
        <div class="feature-card">
          <i class="fas fa-cloud-rain"></i>

          <h3>Rain Alert</h3>

          <p>Avoid spraying pesticides during rainfall.</p>
        </div>

        <div class="feature-card">
          <i class="fas fa-sun"></i>

          <h3>Sunny Weather</h3>

          <p>Ideal for harvesting and drying crops.</p>
        </div>

        <div class="feature-card">
          <i class="fas fa-seedling"></i>

          <h3>Farming Tip</h3>

          <p>Monitor weather regularly for better crop planning.</p>
        </div>
      </div>
    </section>

    <%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/weather.js"></script>
  </body>
</html>
