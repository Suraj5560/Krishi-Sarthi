<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Chatbot | Krishi Sarthi</title>


    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/chatbot.css">

</head>
<body>
 
<%- include("partials/navbar") %>
  <%- include("partials/flash") %> 
<!-- Banner -->

<section class="page-banner">

    <h1>🤖 AI Farming Chatbot</h1>

    <p>
        Ask farming-related questions and receive instant AI assistance.
    </p>

</section>

<!-- Chatbot -->

<section class="chat-container">

    <div class="chat-header">

        <i class="fas fa-robot"></i>

        <h2>Krishi AI Assistant</h2>

    </div>

    <div class="chat-body">

        <div class="message">

            <strong>🤖 AI:</strong>

            Hello Farmer! 👋

            How can I help you today?

        </div>

        <div class="message">

            <strong>👨‍🌾 You:</strong>

            Which crop is best for black soil?

        </div>

        <div class="message">

            <strong>🤖 AI:</strong>

            Cotton, Soybean, Groundnut and Wheat
            are commonly recommended for black soil.

        </div>

    </div>

    <div class="chat-input">

        <form action="/chatbot" method="POST">

            <input
                type="text"
                name="message"
                placeholder="Type your question..."
                required>

            <button type="submit">

                <i class="fas fa-paper-plane"></i>

                Send

            </button>

        </form>

    </div>

</section>

<!-- Quick Questions -->

<section class="features">

<h2>Popular Questions</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-seedling"></i>

<h3>Crop Recommendation</h3>

<p>
Which crop is best for my soil?
</p>

</div>

<div class="feature-card">

<i class="fas fa-leaf"></i>

<h3>Disease Detection</h3>

<p>
How can I identify crop diseases?
</p>

</div>

<div class="feature-card">

<i class="fas fa-cloud-sun"></i>

<h3>Weather Advice</h3>

<p>
Should I irrigate my field today?
</p>

</div>

<div class="feature-card">

<i class="fas fa-money-bill-wave"></i>

<h3>Profit Estimation</h3>

<p>
Which crop provides better profit?
</p>

</div>

</div>

</section>

<!-- Chatbot Features -->

<section class="features">

<h2>What Can AI Help With?</h2>

<div class="feature-grid">

<div class="feature-card">

<i class="fas fa-comments"></i>

<h3>24×7 Support</h3>

<p>
Get farming guidance anytime.
</p>

</div>

<div class="feature-card">

<i class="fas fa-brain"></i>

<h3>AI Suggestions</h3>

<p>
Receive intelligent recommendations.
</p>

</div>

<div class="feature-card">

<i class="fas fa-language"></i>

<h3>Multi-language</h3>

<p>
Support for multiple Indian languages.
</p>

</div>

</div>

</section>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>

</body>
</html>